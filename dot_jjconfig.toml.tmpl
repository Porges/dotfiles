"$schema" = "https://jj-vcs.github.io/jj/latest/config-schema.json"

[user]
name = "George Pollard"
email = {{ .email | quote }}

[revsets]
log = 'present(@) | ancestors(trunk()..(visible_heads() & mine()), 2) | present(trunk())'

[ui]
default-command = "log"
editor = "code.cmd -w"

[templates]
log = "builtin_log_oneline"

[aliases]
b = ["bookmark"]
rt = ["rebase", "-d", "trunk()"] # 'retrunk' https://github.com/fei6409/dotfiles/blob/bce1db7613e555ecb339d6ce16a186fcd6f666e7/jjconfig.toml
l = ["log", "-r", "ancestors(trunk()..@ | trunk(), 2)", "-T", "builtin_log_comfortable"]

[revset-aliases]
HEAD = "@"

[git]
private-commits = "description(glob:'wip:*') | description(glob:'private:*')"

[template-aliases]
'format_short_signature(signature)' = 'signature.email().local()'
'format_timestamp(timestamp)' = 'timestamp.ago()'

[working-copy]
eol-conversion = "input-output"

# use delta as pager for diff and show
[[--scope]]
--when.commands = ["diff", "show"]
[--scope.ui]
# delta requires :git format
pager = "delta"
diff-formatter = ":git"
